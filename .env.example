# Configurazione ambiente — copia in .env sul Raspberry Pi
# cp .env.example .env

# --- Terminale singolo / hub ---
SEDE_ID=1
DEVICE_ID=timbratrice-1

# Hub centralizzato (solo sul server che raccoglie tutto)
# IS_HUB=1
# API_HOST=0.0.0.0

# Terminale remoto: URL dell'hub (lasciare vuoto sull'hub stesso)
# SYNC_URL=http://192.168.1.100:8000
# SYNC_INTERVAL=300

# API REST — stessa chiave su hub e terminali
API_KEY=la-tua-chiave-segreta

# Dashboard — login: admin / admin (cambia subito!)
ADMIN_PASSWORD=admin
DASHBOARD_SECRET=chiave-segreta-random

# Email report mensile (opzionale)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tua-email@gmail.com
SMTP_PASSWORD=password-app
SMTP_FROM=tua-email@gmail.com
REPORT_EMAIL_TO=hr@azienda.it

# Sviluppo senza hardware
# MOCK_GPIO=1
# MOCK_NFC=1
