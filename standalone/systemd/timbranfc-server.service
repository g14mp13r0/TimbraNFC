[Unit]
Description=TimbraNFC — Server e dashboard web (LAN)
After=network.target
Before=timbranfc-kiosk.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/TimbraNFC
EnvironmentFile=-/home/pi/TimbraNFC/.env
Environment=STANDALONE=1
Environment=TIMBRANFC_DATA=/home/pi/TimbraNFC/data
Environment=SERVER_HOST=0.0.0.0
Environment=SERVER_PORT=8080
ExecStart=/home/pi/TimbraNFC/.venv/bin/python standalone/run_server.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
