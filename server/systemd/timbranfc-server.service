[Unit]
Description=TimbraNFC Server di Sede
After=network.target mysql.service

[Service]
User=pi
WorkingDirectory=/home/pi/TimbraNFC
EnvironmentFile=-/home/pi/TimbraNFC/.env
ExecStart=/usr/bin/python3 -m uvicorn server.app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
