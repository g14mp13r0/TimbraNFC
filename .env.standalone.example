# TimbraNFC — Standalone (un solo Raspberry Pi)
# cp .env.standalone.example .env
# Percorso tipico: /home/TUO_UTENTE/TimbraNFC

STANDALONE=1
TIMBRANFC_DATA=/home/gpastorino/TimbraNFC/data

# Server dashboard — accessibile da altri PC: http://<IP-RASPBERRY>:8080
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_URL=http://127.0.0.1:8080

# Sicurezza (opzionale in LAN chiusa)
API_KEY=
SECRET_KEY=genera-una-chiave-random
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin

# Display timbratrice (touchscreen 3.5")
DISPLAY_WIDTH=480
DISPLAY_HEIGHT=320

# Hardware
MOCK_NFC=0
MOCK_GPIO=0
NFC_DEVICE_PATH=usb:072f:2200
NFC_BACKEND=nfcpy
# Touch SPI 3.5" piscreen (320x480 portrait → landscape 480x320 via rotate=90)
TOUCH_ROTATE=left
# Dopo fix-touch-os.sh (swapxy=1 sul piscreen overlay):
TOUCH_FIRMWARE_ROTATED=1
# TOUCH_MATRIX=1 0 0 0 1 0 0 0 1
# Se ancora sfasato, prova overlay: PISCREEN_SWAPXY=1 PISCREEN_INVX=1
# oppure matrice libinput: TOUCH_LIBINPUT_MATRIX="0 -1 1 1 0 0"
