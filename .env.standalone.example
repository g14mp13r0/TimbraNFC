# TimbraNFC — Standalone (un solo Raspberry Pi)
# cp .env.standalone.example .env
# Percorso tipico: /home/TUO_UTENTE/TimbraNFC

STANDALONE=1
TIMBRANFC_DATA=/home/gpastorino/TimbraNFC/data

# Server dashboard — accessibile da altri PC: http://<IP-RASPBERRY>:8080
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_URL=http://127.0.0.1:8080

# Rete LAN Raspberry (Impostazioni → Rete LAN)
# NETWORK_MODE=dhcp
# NETWORK_MODE=manual
# LAN_IP=192.168.178.124
# LAN_SUBNET=255.255.255.0
# LAN_GATEWAY=192.168.178.1
# LAN_DNS=192.168.178.1

# Sicurezza (opzionale in LAN chiusa)
API_KEY=
SECRET_KEY=genera-una-chiave-random
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin

# Display timbratrice (touchscreen 3.5")
DISPLAY_WIDTH=480
DISPLAY_HEIGHT=320

# Hardware
MOCK_NFC=0
MOCK_GPIO=0
NFC_DEVICE_PATH=usb:072f:2200
NFC_BACKEND=nfcpy
# nfcpy richiede pcscd OFF. Alternativa: NFC_MODE=pcsc sudo bash standalone/fix-nfc.sh
# Timbratura solo badge: 1° passaggio = entrata (IT), 2° = uscita (FT)
NFC_AUTO_TIMBRATURA=1
# Per tornare ai 4 pulsanti touch: NFC_AUTO_TIMBRATURA=0
# Lingua kiosk: it | fr | en
KIOSK_LANG=it
KIOSK_CONFIRM_MS=4000
SYNC_INTERVAL_SEC=30
HEARTBEAT_INTERVAL_SEC=120
MIN_SECONDI_TRA_TIMBRATURE=30
# NON impostare finché il touch non funziona:
# TOUCH_FIRMWARE_ROTATED=1
# TOUCH_MATRIX=0 -1 1 1 0 0 0 0 1
