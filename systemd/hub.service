[Unit]
Description=Timbratrice NFC - Hub centralizzato
After=network.target

[Service]
User=pi
WorkingDirectory=/home/pi/TimbraNFC
Environment=IS_HUB=1
Environment=API_HOST=0.0.0.0
Environment=API_KEY=chiave-condivisa-segreta
EnvironmentFile=-/home/pi/TimbraNFC/.env
ExecStart=/usr/bin/python3 main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
